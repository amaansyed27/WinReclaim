{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "WinReclaim",
  "version": "1.0.0",
  "identifier": "com.amaansyed.winreclaim",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "WinReclaim",
        "width": 1180,
        "height": 780,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": true,
        "backgroundColor": "#f3efe4"
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "createUpdaterArtifacts": true,
    "icon": ["icons/icon.ico"],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDg5OUM3Njc5RUZDMDc3RjYKUldUMmQ4RHZlWGFjaVcvVllkT1FPZ2oxLzRjREhxaVNIWUUxaXNFazVNNlpSV2dJL0QwVldJd2YK",
      "endpoints": [
        "https://github.com/amaansyed27/WinReclaim/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}

{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "WinReclaim",
  "version": "1.2.0",
  "identifier": "com.amaansyed.winreclaim",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "WinReclaim",
        "width": 1180,
        "height": 780,
        "minWidth": 760,
        "minHeight": 540,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": false,
        "shadow": true,
        "backgroundColor": "#050a12"
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "msi",
      "nsis"
    ],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDkxOTdFN0VDQUIyRUJCOTEKUldTUnV5NnI3T2VYa1hINnRjNkRhYll5RUdtZDIzZVE4QUlMdStmS0hONHdEWk9XQ0JjSzk2cHUK",
      "endpoints": [
        "https://github.com/amaansyed27/WinReclaim/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
